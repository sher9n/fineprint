# Postgres connection string. Railway injects this automatically when you link a Postgres addon.
# For local dev: postgresql://USER@localhost:5432/fineprint
DATABASE_URL="postgresql://user:password@host:5432/fineprint"
DIRECT_URL="postgresql://user:password@host:5432/fineprint"

# Anthropic API key for Claude. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=""

# OpenAI API key for GPT deep-research (third verification pass). Get one at platform.openai.com.
# Requires an org with deep-research API access enabled.
OPENAI_API_KEY=""
# Override the deep-research model id if needed (default: o3-deep-research).
OPENAI_DEEP_RESEARCH_MODEL="o3-deep-research"
# Daily budget cap for deep-research calls. Tracked separately from DAILY_LLM_BUDGET_USD.
DAILY_DEEP_RESEARCH_BUDGET_USD="50"

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public app URL. http://localhost:3000 for local dev, https://your-domain.com in production.
AUTH_URL="http://localhost:3000"

# Resend for transactional email + magic-link sign-in. Get an API key at resend.com.
# Leave RESEND_API_KEY empty in dev to log magic links to the console instead of sending.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Polyedge <onboarding@resend.dev>"

# Polymarket public API. You can leave this default.
POLYMARKET_GAMMA_URL="https://gamma-api.polymarket.com"

# Daily LLM budget cap in USD. The pipeline stops calling Anthropic when exceeded.
DAILY_LLM_BUDGET_USD="20"

# Display timezone (IANA). All times in the UI are shown in this timezone.
APP_TIMEZONE="Asia/Kolkata"

# Hour of day (in APP_TIMEZONE) when the daily ingest+analyze cron fires.
DAILY_RUN_HOUR_IST="5"

# Comma-separated list of admin emails. Admins see Runs page and admin controls.
ADMIN_EMAILS=""
